# Public app URL used for OAuth callback URLs and CLI examples.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub OAuth app used for owner-only browser login.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ALLOWED_OWNER=

# Private GitHub repo that stores canonical Markdown task files.
TASK_REPO_OWNER=
TASK_REPO_NAME=
TASK_REPO_BRANCH=main
TASK_REPO_TOKEN=

# Shared secret for Codex/Claude/taskctl automation.
TASK_AGENT_TOKEN=

# Cookie signing secret. Generate with: openssl rand -base64 32
SESSION_SECRET=

# Optional read-only import integrations.
GRANOLA_API_KEY=
NOTION_API_TOKEN=
