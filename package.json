{
  "name": "task-command-center",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "taskctl": "./bin/taskctl.mjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright playwright test",
    "e2e:install": "PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright playwright install chromium",
    "taskctl": "node bin/taskctl.mjs",
    "mcp": "node mcp/task-command-center.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "overrides": {
    "postcss": "8.5.14"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
